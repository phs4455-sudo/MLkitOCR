<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/demoHintContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="24dp"
    android:paddingEnd="24dp">

    <LinearLayout
        android:id="@+id/demoHintCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_scanner_hint_hud"
        android:backgroundTint="#CC444444"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:paddingStart="18dp"
        android:paddingEnd="24dp">

        <ImageView
            android:id="@+id/demoHintImage"
            android:layout_width="110dp"
            android:layout_height="72dp"
            android:src="@drawable/demo_passport_mrz"
            android:scaleType="centerInside"
            android:alpha="1.0" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/demoHintTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="여권 스캔"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/demoHintSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="가이드에 맞춰주세요"
                android:textColor="#A6FFFFFF"
                android:textSize="12sp"
                android:letterSpacing="-0.02" />

        </LinearLayout>
    </LinearLayout>
</FrameLayout>
