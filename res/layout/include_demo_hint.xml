<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/demoHintContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="18dp"
    android:paddingEnd="18dp"
    android:paddingTop="6dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:id="@+id/demoHintCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/demo_hint_card_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/demoHintImage"
            android:layout_width="160dp"
            android:layout_height="100dp"
            android:src="@drawable/demo_passport_mrz"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/demoHintTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="여권 MRZ(하단 2줄)을 박스에 맞춰주세요"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/demoHintSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="MRZ 또는 H.Point 바코드를 인식합니다"
                android:textColor="#D1D5DB"
                android:textSize="12sp" />

        </LinearLayout>
    </LinearLayout>
</FrameLayout>
